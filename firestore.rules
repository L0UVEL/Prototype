rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the authenticated user is an admin
    function isAdmin() {
      // Fetch the user's document to check their role.
      // Note: In a production app with high traffic, using Custom Claims is better for performance/cost.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.role == 'admin';
    }

    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- User Collection Rules ---
    match /users/{userId} {
      // Users can access their own document. Admins can access all.
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      // Sub-collections: health_profile, daily_logs
      // Inherit access from parent user document logic (Owner or Admin)
      match /health_profile/{document=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      
      match /health_updates/{document=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // --- Appointments Collection Rules ---
    match /appointments/{appointmentId} {
      // Read: Owner can see their own appointments. Admins can see all.
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Create: Users can create appointments for themselves.
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid);
      
      // Update/Delete: Owner or Admin.
      allow update, delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // --- Announcements Collection Rules ---
    match /announcements/{announcementId} {
      // Read: Any authenticated user can read announcements.
      allow read: if isAuthenticated();
      
      // Write: Only Admins can create/edit/delete announcements.
      allow write: if isAuthenticated() && isAdmin();
    }
    // --- AI Chats Collection Rules ---
    match /ai_chats/{chatId} {
      // Read: Users can see their own chats. Admins can see all.
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Create: Users can only create chats for themselves.
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid);
      
      // Update/Delete: Not allowed for users (chat history is typically immutable)
      allow update, delete: if isAdmin();
    }
    
  }
}
